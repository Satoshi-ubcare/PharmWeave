# ─── Backend ───────────────────────────────────────────────
# Neon PostgreSQL Connection String
# 발급: https://console.neon.tech → Project → Connection Details
DATABASE_URL=postgresql://user:password@host/pharmweave?sslmode=require

# JWT Secret (최소 32자 이상의 랜덤 문자열)
JWT_SECRET=replace-with-minimum-32-char-random-string

# Server
PORT=3000
NODE_ENV=development

# CORS — Frontend 주소 (로컬: http://localhost:5173, 배포: https://pharmweave.vercel.app)
CORS_ORIGIN=http://localhost:5173

# ─── Frontend ──────────────────────────────────────────────
# API Base URL (로컬: http://localhost:3000/api, 배포: https://pharmweave.vercel.app/api)
VITE_API_BASE_URL=http://localhost:3000/api
